"""Hand-written type stub for the subset of `llvmlite.ir` used by Jac.

llvmlite ships no type information; this stub models the public API surface the
native IR-gen pass relies on. It is not a complete model of llvmlite; extend it
as the pass uses more of the library.

IRBuilder methods take `Any` arguments and return the common `Value` base, so a
variable reused across instruction kinds does not collide. `phi` and `alloca`
return their concrete instruction types, whose members (`add_incoming`) and
field types (`AllocaInstr`) callers depend on.
"""

from typing import Any, Iterable

# ─── Types ──────────────────────────────────────────────────────────────────

class Type:
    is_pointer: bool
    null: str
    intrinsic_name: str
    def as_pointer(self, addrspace: int = 0) -> PointerType: ...
    def get_abi_size(self, target_data: Any, context: Any = ...) -> int: ...
    def __eq__(self, other: object) -> bool: ...
    def __hash__(self) -> int: ...

class VoidType(Type):
    def __init__(self) -> None: ...

class LabelType(Type): ...

class MetaDataType(Type): ...

class PointerType(Type):
    pointee: Type
    addrspace: int
    def __init__(self, pointee: Any = ..., addrspace: int = 0) -> None: ...

class IntType(Type):
    width: int
    def __init__(self, bits: int) -> None: ...

class _BaseFloatType(Type): ...
class HalfType(_BaseFloatType): ...
class FloatType(_BaseFloatType): ...
class DoubleType(_BaseFloatType): ...

class FunctionType(Type):
    return_type: Type
    args: tuple[Type, ...]
    var_arg: bool
    def __init__(self, return_type: Any, args: Any, var_arg: bool = False) -> None: ...

class VectorType(Type):
    element: Type
    count: int
    def __init__(self, element: Any, count: int) -> None: ...

class Aggregate(Type):
    elements: tuple[Type, ...]

class ArrayType(Aggregate):
    element: Type
    count: int
    def __init__(self, element: Any, count: int) -> None: ...

class BaseStructType(Aggregate):
    name: str | None

class LiteralStructType(BaseStructType):
    elements: tuple[Type, ...]
    packed: bool
    def __init__(self, elems: Any, packed: bool = False) -> None: ...

class IdentifiedStructType(BaseStructType):
    elements: tuple[Type, ...] | None
    def set_body(self, *elems: Any) -> None: ...

# ─── Values ─────────────────────────────────────────────────────────────────

class Value:
    type: Type
    def __init__(self, *args: Any, **kwargs: Any) -> None: ...
    def set_metadata(self, name: str, node: Any) -> None: ...

class _Undefined: ...

Undefined: _Undefined

class Constant(Value):
    type: Type
    constant: Any
    def __init__(self, typ: Any, constant: Any) -> None: ...
    @staticmethod
    def literal_array(elems: Any) -> Constant: ...
    @staticmethod
    def literal_struct(elems: Any) -> Constant: ...
    def bitcast(self, typ: Any) -> Constant: ...
    def gep(self, indices: Any) -> Constant: ...

class FormattedConstant(Constant): ...

class NamedValue(Value):
    parent: Any
    name: str
    type: Type

class MetaDataString(NamedValue): ...
class MDValue(NamedValue): ...
class DIValue(NamedValue): ...

class DIToken:
    value: str
    def __init__(self, value: str) -> None: ...

class GlobalValue(NamedValue):
    linkage: str
    storage_class: str
    section: str
    def gep(self, indices: Any) -> Constant: ...

class GlobalVariable(GlobalValue):
    value_type: Type
    initializer: Any
    global_constant: bool
    unnamed_addr: bool
    align: int | None
    def __init__(self, module: Any, typ: Any, name: str = "", addrspace: int = 0) -> None: ...

class AttributeSet(set[Any]):
    def add(self, name: str) -> None: ...

class FunctionAttributes(AttributeSet): ...

class Function(GlobalValue):
    ftype: FunctionType
    args: tuple[Argument, ...]
    blocks: list[Block]
    return_value: ReturnValue
    attributes: FunctionAttributes
    calling_convention: str
    def __init__(self, module: Any, typ: Any, name: str = "") -> None: ...
    @property
    def entry_basic_block(self) -> Block: ...
    @property
    def basic_blocks(self) -> list[Block]: ...
    @property
    def function_type(self) -> FunctionType: ...
    @property
    def module(self) -> Module: ...
    @property
    def is_declaration(self) -> bool: ...
    def append_basic_block(self, name: str = "") -> Block: ...

class ArgumentAttributes(AttributeSet): ...

class Argument(NamedValue):
    attributes: ArgumentAttributes

class ReturnValue(NamedValue): ...

class Block(NamedValue):
    scope: Any
    instructions: list[Instruction]
    terminator: Instruction | None
    parent: Function
    @property
    def is_terminated(self) -> bool: ...
    @property
    def function(self) -> Function: ...
    @property
    def module(self) -> Module: ...
    def replace(self, old: Any, new: Any) -> None: ...

# ─── Instructions ───────────────────────────────────────────────────────────

class Instruction(NamedValue):
    opname: str
    operands: tuple[Value, ...]

class CallInstr(Instruction):
    callee: Value
    args: tuple[Value, ...]

class InvokeInstr(CallInstr): ...

class Terminator(Instruction): ...
class Ret(Terminator): ...
class Branch(Terminator): ...
class ConditionalBranch(Terminator): ...
class SwitchInstr(Terminator):
    def add_case(self, val: Any, block: Any) -> None: ...

class SelectInstr(Instruction): ...
class CompareInstr(Instruction): ...
class ICMPInstr(CompareInstr): ...
class FCMPInstr(CompareInstr): ...
class CastInstr(Instruction): ...
class LoadInstr(Instruction): ...
class StoreInstr(Instruction): ...

class AllocaInstr(Instruction):
    def __init__(self, parent: Any, typ: Any, count: Any, name: str = "") -> None: ...

class GEPInstr(Instruction): ...

class PhiInstr(Instruction):
    def add_incoming(self, value: Any, block: Any) -> None: ...

class ExtractValue(Instruction): ...
class InsertValue(Instruction): ...
class Unreachable(Instruction): ...

# ─── Module ─────────────────────────────────────────────────────────────────

class Context:
    def __init__(self) -> None: ...
    def get_identified_type(self, name: str, packed: bool = False) -> IdentifiedStructType: ...

class Module:
    name: str
    context: Context
    data_layout: str
    triple: str
    globals: dict[str, GlobalValue]
    def __init__(self, name: str = "", context: Any = ...) -> None: ...
    @property
    def global_values(self) -> list[GlobalValue]: ...
    def add_global(self, globalvalue: Any) -> None: ...
    def get_global(self, name: str) -> GlobalValue: ...
    def get_unique_name(self, name: str = "") -> str: ...
    def add_named_metadata(self, name: str, element: Any = ...) -> Any: ...
    def add_metadata(self, operands: Any) -> Any: ...
    def add_debug_info(self, kind: str, operands: Any, is_distinct: bool = False) -> Any: ...
    def __str__(self) -> str: ...

# ─── IR builder ─────────────────────────────────────────────────────────────

class IRBuilder:
    block: Block
    function: Function
    module: Module
    def __init__(self, block: Any = ...) -> None: ...
    @property
    def basic_block(self) -> Block: ...
    # positioning
    def position_before(self, instr: Any) -> None: ...
    def position_after(self, instr: Any) -> None: ...
    def position_at_start(self, block: Any) -> None: ...
    def position_at_end(self, block: Any) -> None: ...
    def append_basic_block(self, name: str = "") -> Block: ...
    # memory
    def alloca(self, typ: Any, size: Any = ..., name: str = "") -> AllocaInstr: ...
    def load(self, ptr: Any, name: str = "", align: Any = ..., typ: Any = ...) -> Value: ...
    def store(self, value: Any, ptr: Any, align: Any = ...) -> Value: ...
    def gep(self, ptr: Any, indices: Any, inbounds: bool = False, name: str = "", source_etype: Any = ...) -> Value: ...
    def extract_value(self, agg: Any, idx: Any, name: str = "") -> Value: ...
    def insert_value(self, agg: Any, value: Any, idx: Any, name: str = "") -> Value: ...
    # control flow
    def branch(self, target: Any) -> Value: ...
    def cbranch(self, cond: Any, truebr: Any, falsebr: Any) -> Value: ...
    def switch(self, value: Any, default: Any) -> SwitchInstr: ...
    def ret(self, value: Any) -> Value: ...
    def ret_void(self) -> Value: ...
    def unreachable(self) -> Value: ...
    def call(self, fn: Any, args: Any, name: str = "", cconv: Any = ..., tail: bool = False, fastmath: Any = ..., attrs: Any = ..., arg_attrs: Any = ...) -> Value: ...
    def phi(self, typ: Any, name: str = "", flags: Any = ...) -> PhiInstr: ...
    def select(self, cond: Any, lhs: Any, rhs: Any, name: str = "", flags: Any = ...) -> Value: ...
    # comparisons
    def icmp_signed(self, cmpop: str, lhs: Any, rhs: Any, name: str = "") -> Value: ...
    def icmp_unsigned(self, cmpop: str, lhs: Any, rhs: Any, name: str = "") -> Value: ...
    def fcmp_ordered(self, cmpop: str, lhs: Any, rhs: Any, name: str = "", flags: Any = ...) -> Value: ...
    def fcmp_unordered(self, cmpop: str, lhs: Any, rhs: Any, name: str = "", flags: Any = ...) -> Value: ...
    # integer arithmetic / bitwise
    def add(self, lhs: Any, rhs: Any, name: str = "", flags: Any = ...) -> Value: ...
    def sub(self, lhs: Any, rhs: Any, name: str = "", flags: Any = ...) -> Value: ...
    def mul(self, lhs: Any, rhs: Any, name: str = "", flags: Any = ...) -> Value: ...
    def sdiv(self, lhs: Any, rhs: Any, name: str = "", flags: Any = ...) -> Value: ...
    def udiv(self, lhs: Any, rhs: Any, name: str = "", flags: Any = ...) -> Value: ...
    def srem(self, lhs: Any, rhs: Any, name: str = "", flags: Any = ...) -> Value: ...
    def urem(self, lhs: Any, rhs: Any, name: str = "", flags: Any = ...) -> Value: ...
    def and_(self, lhs: Any, rhs: Any, name: str = "") -> Value: ...
    def or_(self, lhs: Any, rhs: Any, name: str = "") -> Value: ...
    def xor(self, lhs: Any, rhs: Any, name: str = "") -> Value: ...
    def shl(self, lhs: Any, rhs: Any, name: str = "", flags: Any = ...) -> Value: ...
    def ashr(self, lhs: Any, rhs: Any, name: str = "", flags: Any = ...) -> Value: ...
    def lshr(self, lhs: Any, rhs: Any, name: str = "", flags: Any = ...) -> Value: ...
    def not_(self, value: Any, name: str = "") -> Value: ...
    def neg(self, value: Any, name: str = "") -> Value: ...
    # float arithmetic
    def fadd(self, lhs: Any, rhs: Any, name: str = "", flags: Any = ...) -> Value: ...
    def fsub(self, lhs: Any, rhs: Any, name: str = "", flags: Any = ...) -> Value: ...
    def fmul(self, lhs: Any, rhs: Any, name: str = "", flags: Any = ...) -> Value: ...
    def fdiv(self, lhs: Any, rhs: Any, name: str = "", flags: Any = ...) -> Value: ...
    def frem(self, lhs: Any, rhs: Any, name: str = "", flags: Any = ...) -> Value: ...
    # casts
    def trunc(self, value: Any, typ: Any, name: str = "") -> Value: ...
    def zext(self, value: Any, typ: Any, name: str = "") -> Value: ...
    def sext(self, value: Any, typ: Any, name: str = "") -> Value: ...
    def fptrunc(self, value: Any, typ: Any, name: str = "") -> Value: ...
    def fpext(self, value: Any, typ: Any, name: str = "") -> Value: ...
    def fptoui(self, value: Any, typ: Any, name: str = "") -> Value: ...
    def fptosi(self, value: Any, typ: Any, name: str = "") -> Value: ...
    def uitofp(self, value: Any, typ: Any, name: str = "") -> Value: ...
    def sitofp(self, value: Any, typ: Any, name: str = "") -> Value: ...
    def ptrtoint(self, value: Any, typ: Any, name: str = "") -> Value: ...
    def inttoptr(self, value: Any, typ: Any, name: str = "") -> Value: ...
    def bitcast(self, value: Any, typ: Any, name: str = "") -> Value: ...
    def addrspacecast(self, value: Any, typ: Any, name: str = "") -> Value: ...
    # atomics
    def atomic_rmw(self, op: str, ptr: Any, val: Any, ordering: str, name: str = "") -> Value: ...
    def cmpxchg(self, ptr: Any, cmp: Any, val: Any, ordering: str, failordering: Any = ..., name: str = "") -> Value: ...
    def fence(self, ordering: str, targetscope: Any = ..., name: str = "") -> Value: ...
    def comment(self, text: str) -> None: ...
