# Jac IDE runtime environment variables

# Persistent projects root on disk.
# Default if unset: ~/.jac-ide/projects
JAC_IDE_PROJECTS_ROOT=

# Public preview URL template returned by backend after preview start.
# Leave empty for local development (falls back to http://localhost:{port}).
# Supported placeholders: {user_id}, {port}, {api_port}
# Example:
# JAC_IDE_PREVIEW_PUBLIC_URL_TEMPLATE=https://preview.example.com/{user_id}/{port}
JAC_IDE_PREVIEW_PUBLIC_URL_TEMPLATE=

# OpenAI API key for AI Chat (JacCoder agent)
OPENAI_API_KEY=

# Anthropic API key for Claude models (used by byllm when MODEL is a Claude model)
ANTHROPIC_API_KEY=

# LLM model name for JacCoder agent (e.g., gpt-4o, claude-sonnet-4-20250514)
# Overrides jac-coder's default_model config. Reads via os.environ.get("MODEL")
MODEL=

# MCP screenshot server URL for live preview thumbnails.
# Default if unset: https://mcp.jaseci.org
# For local development with jaseci-builder-tools MCP server:
# JAC_MCP_SERVER_URL=http://localhost:8000
JAC_MCP_SERVER_URL=

# JacCoder web mode — auto-allows permissions (no stdin prompts)
# Set to 1 for web deployment (always enabled by JacBuilder)
JACCODER_WEB_MODE=1

# Max concurrent JacCoder agent threads across all users/projects.
# Each worker holds an LLM session + file I/O for the duration of a turn.
# The per-project guard (_ai_processing) prevents duplicate runs on the same project,
# so this only controls how many *different* projects can run agents simultaneously.
# Default: 2 (suitable for single-user dev). Increase for multi-user deployments.
JACCODER_MAX_WORKERS=8


# ===========================================================================
# SSO Authentication
# ===========================================================================

# Google OAuth (SSO login)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# GitHub OAuth App 1 — SSO login ("Continue with GitHub")
# Create at: https://github.com/settings/applications/new
# Callback URL: http://localhost:8000/sso/github/callback
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""



# ===========================================================================
# GitHub Repo Operations (separate OAuth App)
# ===========================================================================
# GitHub OAuth App 2 — Repo operations (push, pull, create repo, PRs)
# Create at: https://github.com/settings/applications/new
# Callback URL: http://localhost:8000/auth/github-connect
GITHUB_REPO_CLIENT_ID=""
GITHUB_REPO_CLIENT_SECRET=""


# ===========================================================================
# Server
# ===========================================================================

HOST=http://localhost:8000
CLIENT_AUTH_CALLBACK_URL=http://localhost:8000/auth/callback
