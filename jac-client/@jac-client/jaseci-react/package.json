{
  "name": "@jaseci/react",
  "version": "0.1.0",
  "description": "React hooks for Jac backends - call walkers, manage auth, subscribe to graph changes",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --external react",
    "dev": "tsup src/index.ts --format esm,cjs --dts --external react --watch"
  },
  "peerDependencies": {
    "react": ">=17.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "react": "^18.3.1",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "keywords": [
    "jac",
    "jaseci",
    "react",
    "hooks",
    "walkers",
    "graph",
    "agents"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jaseci-labs/jaseci.git",
    "directory": "jac-client/@jac-client/jaseci-react"
  }
}
