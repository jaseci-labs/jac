"""Implementation of the generated test file writer."""

import re;
import os;
import from datetime { datetime, timezone }
import from pathlib { Path }
import from loguru { logger }
import from byllm.test_gen.code_generator { TestGenResult }

impl read_existing_hashes(output_path: str) -> dict[str, str] {
    result: dict[str, str] = {};
    try {
        content = Path(output_path).read_text(encoding="utf-8");
        for m in re.finditer(r"# --- spec_hash:(\w+):([0-9a-f]+) ---", content) {
            result[m.group(1)] = m.group(2);
        }
    } except FileNotFoundError {
        ;
    }
    return result;
}

impl write_test_file(
    results: list[TestGenResult],
    source_file: str,
    output_path: str
) -> None {
    source_path = Path(source_file);
    source_stem = source_path.stem;
    # Handle multi-extension stems like foo.impl
    if source_stem.endswith(".impl") {
        source_stem = source_stem[:-5];
    }

    now = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ");
    successful = [r for r in results if r.test_code is not None];
    failed = [r for r in results if r.test_code is None];

    header_lines: list[str] = [
        "# AUTO-GENERATED by `jac test-gen` — DO NOT EDIT BY HAND",
        f"# Source: {source_path.name}",
        f"# Generated: {now}",
        "# Re-run `jac test-gen <source_file>` to regenerate after spec changes.",
        "# Tests call a real LLM — configure model via jac.toml [plugins.byllm].",
        "",
        "import re;",
    ];

    if failed {
        header_lines.append("#");
        header_lines.append(f"# NOTE: {len(failed)} function(s) failed test generation:");
        for r in failed {
            # Prefix every line of the error with # so multiline errors don't break the file
            error_lines = (r.error or "").splitlines();
            first_line = error_lines[0] if error_lines else "";
            header_lines.append(f"#   - {r.spec.name}: {first_line}");
            for extra in error_lines[1:] {
                header_lines.append(f"#     {extra}");
            }
        }
    }
    header_lines.append("");

    blocks: list[str] = [];
    for r in successful {
        hash_str = r.spec.spec_hash();
        blocks.append(f"# --- spec_hash:{r.spec.name}:{hash_str} ---");
        blocks.append(r.test_code);
        blocks.append("");
    }

    output_parts: list[str] = [
        "\n".join(header_lines),
        "\n".join(blocks),
    ];
    content = "\n".join(output_parts).rstrip() + "\n";

    # Ensure output directory exists
    out_path = Path(output_path);
    out_path.parent.mkdir(parents=True, exist_ok=True);

    out_path.write_text(content, encoding="utf-8");
    logger.info(f"[test-gen] Wrote {len(successful)} test(s) to {output_path}");
    if failed {
        logger.warning(f"[test-gen] {len(failed)} function(s) could not be generated — see header comments in output file");
    }
}
